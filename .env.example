# --- Database ---
# "db" is the Postgres service name in docker-compose.yml — keep as-is for
# Docker deployments. For local dev without Docker, point at localhost instead
# (e.g. sqlite+aiosqlite:///./dev.db, or a local Postgres on localhost:5432).
DATABASE_URL=postgresql+asyncpg://diablogram:diablogram@db:5432/diablogram

# --- Telegram API (my.telegram.org, needed by Telethon for every account) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Notification bot (separate Bot API token, DMs you on account status changes) ---
NOTIFIER_BOT_TOKEN=
NOTIFIER_OWNER_CHAT_ID=

# --- AI provider ---
# One of: anthropic, openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Only needed for OpenAI-compatible third-party providers/resellers (e.g. NordRouter).
# Leave empty to use the official OpenAI API.
OPENAI_BASE_URL=

# --- Security ---
# 32-byte urlsafe base64 key for encrypting session strings/proxy passwords at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# --- Web panel ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
